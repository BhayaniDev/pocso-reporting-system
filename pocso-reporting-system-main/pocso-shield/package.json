{
  "name": "pocso-shield",
  "version": "1.0.0",
  "description": "Blockchain-based anonymous POCSO reporting system",
  "scripts": {
    "compile":   "npx hardhat compile",
    "deploy:local": "npx hardhat run scripts/deploy.js --network hardhat",
